<?xml version="1.0"?>
<Container version="2">
  <Name>ArgusFlix-Custom</Name>
  <Repository>ghcr.io/argusflix_manager/argusflix_manager:latest</Repository>
  <Registry>https://github.com/argusflix_manager/argusflix_manager/pkgs/container/argusflix_manager</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/argusflix_manager/argusflix_manager/issues</Support>
  <Project>https://github.com/argusflix_manager/argusflix_manager</Project>
  <Overview>Customized ArgusFlix instance with plugins and scripts.</Overview>
  <Category>MediaApp:Video MediaServer:Video</Category>
  <WebUI>http://[IP]:[PORT:9191]</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/argusflix_manager/argusflix_manager/main/frontend/public/logo512.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI Port" Target="9191" Default="8383" Mode="tcp" Description="The port to access the ArgusFlix WebUI." Type="Port" Display="always" Required="true" Mask="false">8383</Config>
  <Config Name="Data Path" Target="/data" Default="/mnt/user/appdata/argusflix_manager/data" Mode="rw" Description="Path for database, logs, and uploads." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/argusflix_manager/data</Config>
  <Config Name="Plugins Path" Target="/data/plugins" Default="/mnt/user/appdata/argusflix_manager/plugins" Mode="rw" Description="Path for custom plugins." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/argusflix_manager/plugins</Config>
  <Config Name="Scripts Path" Target="/data/scripts" Default="/mnt/user/appdata/argusflix_manager/scripts" Mode="rw" Description="Path for custom scripts." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/argusflix_manager/scripts</Config>
  <Config Name="ArgusFlix Environment" Target="ARGUSFLIX_ENV" Default="aio" Mode="" Description="Environment mode for ArgusFlix (aio = All-in-One)." Type="Variable" Display="always" Required="true" Mask="false">aio</Config>
  <Config Name="Allowed Script Directories" Target="ARGUSFLIX_ALLOWED_SCRIPT_DIRS" Default="/data/scripts" Mode="" Description="Directories where scripts are allowed to execute." Type="Variable" Display="always" Required="false" Mask="false">/data/scripts</Config>
  <Config Name="Timezone" Target="TZ" Default="Europe/Berlin" Mode="" Description="Your local timezone." Type="Variable" Display="advanced" Required="false" Mask="false">Europe/Berlin</Config>
  <Config Name="Redis Host" Target="REDIS_HOST" Default="localhost" Mode="" Description="Local Redis host (for AIO mode)." Type="Variable" Display="advanced" Required="false" Mask="false">localhost</Config>
  <Config Name="Celery Broker URL" Target="CELERY_BROKER_URL" Default="redis://localhost:6379/0" Mode="" Description="Celery connection to Redis." Type="Variable" Display="advanced" Required="false" Mask="false">redis://localhost:6379/0</Config>
</Container>
