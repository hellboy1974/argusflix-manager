+def _sd_image_width(img):
+    try:
+        return int(img.get('width') or 0)
+    except (TypeError, ValueError):
+        return 0
+
+
+def _sd_is_primary(img):
+    val = img.get('primary')
+    if val is True:
+        return True
+    if isinstance(val, str):
+        return val.lower() in ('true', '1', 'yes')
+    return False
+
