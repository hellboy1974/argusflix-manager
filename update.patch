+        showNotification({
+          title: 'Lineup removed',
+          message: lineup.name,
+          color: 'blue',
+        });
+        if (
+          result.changes_remaining !== undefined &&
+          result.changes_remaining !== null
+        ) {
+          setChangesRemaining(result.changes_remaining);
+        }
