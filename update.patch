+vi.mock('../../../utils/forms/UserUtils.js', () => ({
+  createUser: vi.fn(),
+  updateUser: vi.fn(),
+  generateApiKey: vi.fn(),
+  revokeApiKey: vi.fn(),
+  formValuesToPayload: vi.fn(),
+  getFormInitialValues: vi.fn(() => ({})),
+  getFormValidators: vi.fn(() => ({})),
+  userToFormValues: vi.fn(() => ({})),
+}));
+
+// ── Mantine form ───────────────────────────────────────────────────────────────
+const mockForm = {
+  getInputProps: vi.fn(() => ({})),
+  key: vi.fn((k) => k),
+  setValues: vi.fn(),
+  setFieldValue: vi.fn(),
+  reset: vi.fn(),
