+
+vi.mock('@mantine/form', () => ({
+  useForm: vi.fn(() => mockForm),
+}));
+
+// ── lucide-react ───────────────────────────────────────────────────────────────
+vi.mock('lucide-react', () => ({
+  Copy: () => <svg data-testid="icon-copy" />,
+  Key: () => <svg data-testid="icon-key" />,
